#: src/vibetuner/frontend/email.py
#, python-brace-format
msgid "Sign in to {project_name}"
msgstr "Inicia la sessió a {project_name}"

#: src/vibetuner/templates/frontend/email_sent.html.jinja
msgid "Check Your Email"
msgstr "Revisa el teu correu"

#: src/vibetuner/templates/frontend/email_sent.html.jinja
msgid "We've sent a secure login link to"
msgstr "Hem enviat un enllaç segur d'inici de sessió a"

#: src/vibetuner/templates/frontend/email_sent.html.jinja
msgid "Quick! Link expires in 15 minutes"
msgstr "Ràpid! L'enllaç caduca en 15 minuts"

#: src/vibetuner/templates/frontend/email_sent.html.jinja
msgid "Click the link in the email to sign in instantly."
msgstr "Fes clic a l'enllaç del correu per iniciar la sessió a l'instant."

#: src/vibetuner/templates/frontend/email_sent.html.jinja
msgid "Don't see the email?"
msgstr "No veus el correu?"

#: src/vibetuner/templates/frontend/email_sent.html.jinja
msgid "Check your spam folder or try signing in again."
msgstr ""
"Comprova la carpeta de correu brossa o torna a provar d'iniciar sessió."

#: src/vibetuner/templates/frontend/email_sent.html.jinja
msgid "Try Again"
msgstr "Torna-ho a provar"

#: src/vibetuner/templates/frontend/email_sent.html.jinja
msgid "Back to Home"
msgstr "Torna a l'inici"

#: src/vibetuner/templates/frontend/email_sent.html.jinja
msgid "This link is secure and can only be used once"
msgstr "Aquest enllaç és segur i només es pot fer servir una vegada"

#: src/vibetuner/templates/frontend/login.html.jinja
msgid "Sign In"
msgstr "Inicia la sessió"

#: src/vibetuner/templates/frontend/login.html.jinja
msgid "Welcome Back"
msgstr "Et donem la benvinguda de nou"

#: src/vibetuner/templates/frontend/login.html.jinja
msgid "Choose your preferred sign-in method"
msgstr "Tria el teu mètode d'inici de sessió preferit"

#: src/vibetuner/templates/frontend/login.html.jinja
#, python-format
msgid "Continue with %(provider)s"
msgstr "Continua amb %(provider)s"

#: src/vibetuner/templates/frontend/login.html.jinja
msgid "OR"
msgstr "O BÉ"

#: src/vibetuner/templates/frontend/login.html.jinja
#: src/vibetuner/templates/frontend/user/edit.html.jinja
#: src/vibetuner/templates/frontend/user/profile.html.jinja
msgid "Email Address"
msgstr "Adreça de correu electrònic"

#: src/vibetuner/templates/frontend/login.html.jinja
msgid "Enter your email address"
msgstr "Introdueix la teva adreça de correu electrònic"

#: src/vibetuner/templates/frontend/login.html.jinja
msgid "Send Magic Link"
msgstr "Envia l'enllaç màgic"

#: src/vibetuner/templates/frontend/login.html.jinja
msgid "No password required!"
msgstr "No cal contrasenya!"

#: src/vibetuner/templates/frontend/login.html.jinja
msgid "We'll send you a secure link to sign in instantly."
msgstr "T'enviarem un enllaç segur per iniciar la sessió a l'instant."

#: src/vibetuner/templates/frontend/auth/logout_confirm.html.jinja
msgid "Confirm sign out"
msgstr "Confirma el tancament de sessió"

#: src/vibetuner/templates/frontend/auth/logout_confirm.html.jinja
msgid "Click the button below to end your session."
msgstr "Fes clic al botó de sota per finalitzar la sessió."

#: src/vibetuner/templates/frontend/auth/logout_confirm.html.jinja
#: src/vibetuner/templates/frontend/user/profile.html.jinja
msgid "Sign Out"
msgstr "Tanca la sessió"

#: src/vibetuner/templates/frontend/auth/logout_confirm.html.jinja
#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid "Cancel"
msgstr "Cancel·la"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
#: src/vibetuner/templates/frontend/user/profile.html.jinja
msgid "Edit Profile"
msgstr "Edita el perfil"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid "Update your account information and preferences"
msgstr "Actualitza la informació i les preferències del teu compte"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid "Display Name"
msgstr "Nom visible"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid "This name will be displayed throughout the application"
msgstr "Aquest nom es mostrarà arreu de l'aplicació"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
#: src/vibetuner/templates/frontend/user/profile.html.jinja
msgid "Preferred Language"
msgstr "Idioma preferit"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid "Use browser default"
msgstr "Fes servir el predeterminat del navegador"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid "This will override browser language detection"
msgstr "Això anul·larà la detecció d'idioma del navegador"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid "Email cannot be changed and is managed through your OAuth provider"
msgstr ""
"El correu electrònic no es pot canviar i es gestiona des del teu proveïdor "
"OAuth"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid "Save Changes"
msgstr "Desa els canvis"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid "About Language Preferences"
msgstr "Sobre les preferències d'idioma"

#: src/vibetuner/templates/frontend/user/edit.html.jinja
msgid ""
"Your language preference will take priority over URL parameters, cookies, "
"and browser settings. Leave empty to use automatic detection."
msgstr ""
"La teva preferència d'idioma té prioritat sobre els paràmetres de l'URL, les "
"galetes i la configuració del navegador. Deixa-ho buit per fer servir la "
"detecció automàtica."

