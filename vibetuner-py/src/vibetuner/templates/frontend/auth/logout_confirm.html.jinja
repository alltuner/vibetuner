{% extends "base/skeleton.html.jinja" %}

{% block title %}
    {{ _("Confirm sign out") }}
{% endblock title %}
{% block body %}
    <div class="min-h-screen bg-base-200 flex items-center justify-center p-4">
        <div class="card w-full max-w-md bg-base-100 shadow-2xl">
            <div class="card-body text-center">
                <h1 class="text-2xl font-bold text-base-content mb-2">{{ _("Confirm sign out") }}</h1>
                <p class="text-base-content/70 mb-6">{{ _("Click the button below to end your session.") }}</p>
                <form method="post" action="{{ url_for('auth_logout') }}" class="space-y-3">
                    <button type="submit" class="btn btn-error btn-block">{{ _("Sign Out") }}</button>
                    <a href="{{ url_for('homepage') }}" class="btn btn-ghost btn-block">{{ _("Cancel") }}</a>
                </form>
            </div>
        </div>
    </div>
{% endblock body %}
